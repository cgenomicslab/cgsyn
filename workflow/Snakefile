# ===== METHOD COMPARISON =====

rule compare_methods:
    output:
        report = "logs/orthology_comparison.txt"
    params:
        ortho_dir = f"{RESULTS_DIR}/orthofinder/orthologues_path.txt",
        rbh_dir = f"{RESULTS_DIR}/rbh"
    log:
        "logs/compare_methods.log"
    script:
        "scripts/run_compare_methods.py"

# ===== GENE ANALYSIS =====

rule gene_analysis:
    input:
        rbh_files = lambda wildcards: [
            f"{RESULTS_DIR}/rbh/Orthologues_{species1}/{species1}__v__{species2}.tsv.tsv"
            for sp1, sp2 in SPECIES_PAIRS
        ],
        tsv_files = expand("intermediates/tsv/{species}.tsv", species=SPECIES)
    output:
        families = f"{RESULTS_DIR}/gene_analysis/gene_families.tsv",
        details = f"{RESULTS_DIR}/gene_analysis/gene_family_details.txt"
    params:
        triangle = config["gene_analysis"]["triangle_species"],
        rest = config["gene_analysis"]["rest_species"],
        mbh = config["gene_analysis"]["mbh"],
        rbh_dir = f"{RESULTS_DIR}/rbh",
        tsv_dir = config["tsv_dir"]
    log:
        "logs/gene_analysis.log"
    script:
        "scripts/run_gene_analysis.py"
