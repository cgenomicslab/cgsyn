# ===== RBH RULES =====

rule run_rbh:
    output:
        orthogroups = f"{RESULTS_DIR}/rbh/MBH_Orthogroups.tsv",
    params:
        proteome_dir = config["filtered_proteome_dir"],
        output_dir = f"{RESULTS_DIR}/rbh",
        threads = config["rbh"]["threads"],
        aligner = config["rbh"]["aligner"],
        tsv_dir = config["tsv_dir"],
    log:
        "logs/rbh.log"
    run:
        import sys
        sys.path.insert(0, "workflow/scripts")
        from synteny import find_mutual_best_hits_multi, save_orthology_heatmap
        find_mutual_best_hits_multi(
            species_list=SPECIES,
            proteome_dir=params.proteome_dir,
            output_dir=params.output_dir,
            num_threads=params.threads,
            aligner=params.aligner
        )
        save_orthology_heatmap(
            species_list=SPECIES,
            rbh_dir=params.output_dir,
            tsv_dir=params.tsv_dir,
            output_path=f"{params.output_dir}/orthology_heatmap.png",
            mode='rbh'
        )

