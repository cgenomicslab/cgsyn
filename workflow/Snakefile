import itertools
from pathlib import Path

# Load configuration
configfile: "config/config.yaml"

# Override config with command-line arguments if provided
if config.get("cli_override"):
    pass

# Import your functions
import sys
sys.path.insert(0, "workflow/scripts")
from synteny import *

# Get all species and species pairs
SPECIES = config["species"]
SPECIES_PAIRS = list(itertools.combinations(SPECIES, 2))

# Determine which outputs to generate based on config settings
def get_final_outputs():
    outputs = []
    
    if config["run_parsing"]:
        outputs.extend([
            f"intermediates/tsv/{sp}.tsv"
            for sp in SPECIES
        ])
    
    if config["run_orthofinder"]:
        outputs.append("results/orthofinder/done.txt")
    
    if config["run_rbh"]:
        outputs.append("results/rbh/MBH_Orthogroups.tsv")
    
    if config["run_dotplots_orthofinder"]:
        outputs.extend([
            f"results/dotplots_orthofinder/{sp1}_vs_{sp2}.png"
            for sp1, sp2 in SPECIES_PAIRS
        ])
    
    if config["run_dotplots_rbh"]:
        outputs.extend([
            f"results/dotplots_rbh/{sp1}_vs_{sp2}.png"
            for sp1, sp2 in SPECIES_PAIRS
        ])
    
    if config["run_ribbons_orthofinder"]:
        outputs.extend([
            f"results/ribbons_orthofinder/{sp1}_vs_{sp2}.png"
            for sp1, sp2 in SPECIES_PAIRS
        ])
    
    if config["run_ribbons_rbh"]:
        outputs.extend([
            f"results/ribbons_rbh/{sp1}_vs_{sp2}.png"
            for sp1, sp2 in SPECIES_PAIRS
        ])
    
    if config["run_alg_discovery_orthofinder"]:
        outputs.extend([
            "results/alg_orthofinder/alg_results.pkl",
            "results/alg_orthofinder/alg_summary.txt"
        ])
    
    if config["run_alg_discovery_rbh"]:
        outputs.extend([
            "results/alg_rbh/alg_results.pkl",
            "results/alg_rbh/alg_summary.txt"
        ])
    
    if config["run_ribbons_multi_orthofinder"]:
        outputs.append("results/ribbons_multi_orthofinder/multi_species_ribbon.png")
    
    if config["run_ribbons_multi_rbh"]:
        outputs.append("results/ribbons_multi_rbh/multi_species_ribbon.png")
    
    if config["run_gene_analysis"]:
        outputs.append("results/gene_analysis/gene_families.tsv")
    
    return outputs

# Target rule
rule all:
    input:
        get_final_outputs()

# ===== PARSING RULES =====

rule parse_gff_proteome:
    input:
        gff = lambda wildcards: f"{config['gff_dir']}/{wildcards.species}.gff.gz",
        proteome = lambda wildcards: f"{config['proteome_dir']}/{wildcards.species}.faa.gz"
    output:
        filtered_proteome = "intermediates/filtered_proteomes/{species}.faa",
        tsv = "intermediates/tsv/{species}.tsv"
    log:
        "logs/parse_{species}.log"
    script:
        "scripts/run_parsing.py"

# ===== ORTHOFINDER RULES =====

rule run_orthofinder:
    input:
        proteomes = expand("intermediates/filtered_proteomes/{species}.faa",
                          species=SPECIES)
    output:
        done = "results/orthofinder/done.txt",
        ortho_path = "results/orthofinder/orthologues_path.txt"
    params:
        proteome_dir = config["filtered_proteome_dir"],
        threads = config["orthofinder"]["threads"],
        aligner = config["orthofinder"]["aligner"]
    log:
        "logs/orthofinder.log"
    shell:
        """
        python -c "
import sys
sys.path.insert(0, 'workflow/scripts')
from synteny import run_orthofinder
ortho_path = run_orthofinder(
    filtered_prot_dir='{params.proteome_dir}',
    num_threads={params.threads},
    aligner='{params.aligner}',
    output_dir='results/orthofinder'
)
with open('{output.ortho_path}', 'w') as f:
    f.write(ortho_path)
" > {log} 2>&1 && touch {output.done}
        """

rule orthofinder_dotplot:
    input:
        orthofinder_done = "results/orthofinder/done.txt",
        ortho_path = "results/orthofinder/orthologues_path.txt",
        tsv1 = "intermediates/tsv/{species1}.tsv",
        tsv2 = "intermediates/tsv/{species2}.tsv"
    output:
        plot = "results/dotplots_orthofinder/{species1}_vs_{species2}.png"
    params:
        sp1 = lambda wildcards: wildcards.species1,
        sp2 = lambda wildcards: wildcards.species2,
        ortho_dir = lambda wildcards, input: open(input.ortho_path).read().strip(),
        tsv_dir = config["tsv_dir"],
        alpha = config["fishers"]["alpha"],
        min_matches = config["fishers"]["min_matches"],
        dot_size = config["dotplot"]["dot_size"],
        dot_alpha = config["dotplot"]["dot_alpha"]
    log:
        "logs/dotplot_orthofinder_{species1}_{species2}.log"
    script:
        "scripts/run_dotplot_orthofinder.py"

