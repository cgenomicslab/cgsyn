rule alg_discovery_orthofinder:
    input:
        orthofinder_done = "results/orthofinder/done.txt",
        ortho_path = "results/orthofinder/orthologues_path.txt",
        tsv_files = expand("intermediates/tsv/{species}.tsv", species=SPECIES)
    output:
        alg_results = "results/alg_orthofinder/alg_results.pkl",
        alg_summary = "results/alg_orthofinder/alg_summary.txt"
    params:
        species_list = SPECIES,
        ortho_dir = lambda wildcards, input: open(input.ortho_path).read().strip(),
        tsv_dir = config["tsv_dir"],
        alpha = config["fishers"]["alpha"],
        min_matches = config["fishers"]["min_matches"],
        similarity_threshold = config.get("alg", {}).get("similarity_threshold", 0.3),
        min_orthologs = config.get("alg", {}).get("min_orthologs", 10)
    log:
        "logs/alg_discovery_orthofinder.log"
    script:
        "scripts/run_alg_discovery_orthofinder.py"

rule orthofinder_ribbons_multi:
    input:
        orthofinder_done = "results/orthofinder/done.txt",
        ortho_path = "results/orthofinder/orthologues_path.txt",
        tsv_files = expand("intermediates/tsv/{species}.tsv", species=SPECIES)
    output:
        plot = "results/ribbons_multi_orthofinder/multi_species_ribbon.png"
    params:
        species_list = SPECIES,
        ortho_dir = lambda wildcards, input: open(input.ortho_path).read().strip(),
        tsv_dir = config["tsv_dir"],
        alpha = config["fishers"]["alpha"],
        min_matches = config["fishers"]["min_matches"],
        ribbon_alpha = config["ribbons_multi"]["ribbon_alpha"],
        figsize = config["ribbons_multi"]["figsize"],
        curve_style = config["ribbons_multi"]["curve_style"],
        alg_discovery = config.get("run_alg_discovery_orthofinder", False),
        alg_results_path = "results/alg_orthofinder/alg_results.pkl",
        alg_summary_path = "results/alg_orthofinder/alg_summary.txt",
        similarity_threshold = config.get("alg", {}).get("similarity_threshold", 0.3),
        min_orthologs = config.get("alg", {}).get("min_orthologs", 10)
    log:
        "logs/ribbons_multi_orthofinder.log"
    script:
        "scripts/run_ribbons_multi_orthofinder.py"

# ===== RBH RULES =====

rule run_rbh:
    input:
        proteomes = expand(
            "intermediates/filtered_proteomes/{species}.faa",
            species=SPECIES
        )
    output:
        orthogroups = "results/rbh/MBH_Orthogroups.tsv",
        pairwise_tsvs = expand(
            "results/rbh/Orthologues_{sp1}/{sp1}__v__{sp2}.tsv",
            zip,
            sp1=[sp1 for sp1, sp2 in SPECIES_PAIRS],
            sp2=[sp2 for sp1, sp2 in SPECIES_PAIRS]
        )
    params:
        species_list = SPECIES,
        proteome_dir = config["filtered_proteome_dir"],
        output_dir = "results/rbh",
        threads = config["rbh"]["threads"],
        aligner = config["rbh"]["aligner"]
    log:
        "logs/rbh.log"
    run:
        import sys
        sys.path.insert(0, "workflow/scripts")
        from synteny import find_mutual_best_hits_multi
        find_mutual_best_hits_multi(
            species_list=params.species_list,
            proteome_dir=params.proteome_dir,
            output_dir=params.output_dir,
            num_threads=params.threads,
            aligner=params.aligner
        )

