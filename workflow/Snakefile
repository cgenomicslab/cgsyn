import itertools
from pathlib import Path
import os

# Load configuration
configfile: "config/config.yaml"

# Override config with command-line arguments if provided
if config.get("cli_override"):
    pass

# Import your functions
import sys
sys.path.insert(0, "workflow/scripts")
from synteny import *

# Get all species and species pairs
SPECIES = config.get("species", [])
SPECIES_PAIRS = list(itertools.combinations(SPECIES, 2))

RESULTS_DIR = config.get("results_dir", "results")
SHARED_OGS = config.get("shared_ogs", False)
CLUSTER_SPECIES = config.get("alg", {}).get("cluster_species", True)

def get_alg_subdir():
    if SHARED_OGS and not CLUSTER_SPECIES:
        return "_shared_ogs_no_cluster"
    elif SHARED_OGS:
        return "_shared_ogs"
    elif not CLUSTER_SPECIES:
        return "_no_cluster"
    else:
        return ""

ALG_SUBDIR = get_alg_subdir()

# Determine which outputs to generate based on config settings
def get_final_outputs():
    outputs = []

    if config["run_parsing"]:
        outputs.extend([
            f"intermediates/tsv/{sp}.tsv"
            for sp in SPECIES
        ])

    if config["run_orthofinder"]:
        outputs.append(f"{RESULTS_DIR}/orthofinder/done.txt")

    if config["run_rbh"]:
        outputs.append(f"{RESULTS_DIR}/rbh/MBH_Orthogroups.tsv")

    if config["run_dotplots_orthofinder"]:
        outputs.extend([
            f"{RESULTS_DIR}/dotplots_orthofinder{ALG_SUBDIR}/{sp1}_vs_{sp2}.png"
            for sp1, sp2 in SPECIES_PAIRS
        ])

    if config["run_dotplots_rbh"]:
        outputs.extend([
            f"{RESULTS_DIR}/dotplots_rbh/{sp1}_vs_{sp2}.png"
            for sp1, sp2 in SPECIES_PAIRS
        ])

    if config["run_ribbons_orthofinder"]:
        outputs.extend([
            f"{RESULTS_DIR}/ribbons_orthofinder{ALG_SUBDIR}/{sp1}_vs_{sp2}.png"
            for sp1, sp2 in SPECIES_PAIRS
        ])

    if config["run_ribbons_rbh"]:
        outputs.extend([
            f"{RESULTS_DIR}/ribbons_rbh/{sp1}_vs_{sp2}.png"
            for sp1, sp2 in SPECIES_PAIRS
        ])

    if config["run_alg_discovery_orthofinder"]:
        outputs.extend([
            f"{RESULTS_DIR}/alg_orthofinder{ALG_SUBDIR}/alg_results.pkl",
            f"{RESULTS_DIR}/alg_orthofinder{ALG_SUBDIR}/alg_summary.txt"
        ])

    if config["run_alg_discovery_rbh"]:
        outputs.extend([
            f"{RESULTS_DIR}/alg_rbh{ALG_SUBDIR}/alg_results.pkl",
            f"{RESULTS_DIR}/alg_rbh{ALG_SUBDIR}/alg_summary.txt"
        ])

    if config["run_ribbons_multi_orthofinder"]:
        outputs.append(f"{RESULTS_DIR}/ribbons_multi_orthofinder{ALG_SUBDIR}/multi_species_ribbon.png")

    if config["run_ribbons_multi_rbh"]:
        outputs.append(f"{RESULTS_DIR}/ribbons_multi_rbh{ALG_SUBDIR}/multi_species_ribbon.png")

    if config["run_compare_methods"]:
        outputs.append("logs/orthology_comparison.txt")

    if config["run_gene_analysis"]:
        outputs.append(f"{RESULTS_DIR}/gene_analysis/gene_families.tsv")

    return outputs

# Target rule
rule all:
    input:
        get_final_outputs()

# ===== PARSING RULES =====

rule parse_gff_proteome:
    input:
        gff = lambda wildcards: f"{config['gff_dir']}/{wildcards.species}.gff.gz",
        proteome = lambda wildcards: f"{config['proteome_dir']}/{wildcards.species}.faa.gz"
    output:
        filtered_proteome = "intermediates/filtered_proteomes/{species}.faa",
        tsv = "intermediates/tsv/{species}.tsv"
    log:
        "logs/parse_{species}.log"
    script:
        "scripts/run_parsing.py"

# ===== ORTHOFINDER RULES =====

rule run_orthofinder:
    output:
        done = f"{RESULTS_DIR}/orthofinder/done.txt",
        ortho_path = f"{RESULTS_DIR}/orthofinder/orthologues_path.txt"
    params:
        proteome_dir = config["filtered_proteome_dir"],
        threads = config["orthofinder"]["threads"],
        aligner = config["orthofinder"]["aligner"],
        inflation = config["orthofinder"].get("inflation", 1.2),
        tree_method = config["orthofinder"].get("tree_method", "msa"),
        msa_program = config["orthofinder"].get("msa_program", "famsa"),
        tree_inference = config["orthofinder"].get("tree_inference", "fasttree"),
        tsv_dir = config["tsv_dir"],
        results_dir = RESULTS_DIR
    log:
        "logs/orthofinder.log"
    run:
        import sys, os
        sys.path.insert(0, "workflow/scripts")
        from synteny import run_orthofinder, save_orthology_heatmap
        ortho_path = run_orthofinder(
            filtered_prot_dir=params.proteome_dir,
            species_list=SPECIES,
            num_threads=params.threads,
            aligner=params.aligner,
            inflation=params.inflation,
            tree_method=params.tree_method,
            msa_program=params.msa_program,
            tree_inference=params.tree_inference,
            output_dir=str(output.done).replace("/done.txt", "")
        )
        with open(output.ortho_path, 'w') as f:
            f.write(ortho_path)
        open(output.done, 'w').close()
        save_orthology_heatmap(
            species_list=SPECIES,
            orthofinder_dir=ortho_path,
            tsv_dir=params.tsv_dir,
            output_path=f"{params.results_dir}/orthofinder/orthology_heatmap.png",
            mode='orthofinder'
        )

rule orthofinder_dotplot:
    input:
        tsv1 = "intermediates/tsv/{species1}.tsv",
        tsv2 = "intermediates/tsv/{species2}.tsv"
    output:
        plot = f"{RESULTS_DIR}/dotplots_orthofinder{ALG_SUBDIR}/{{species1}}_vs_{{species2}}.png"
    params:
        sp1 = lambda wildcards: wildcards.species1,
        sp2 = lambda wildcards: wildcards.species2,
        tsv_dir = config["tsv_dir"],
        alpha = config["fishers"]["alpha"],
        min_matches = config["fishers"]["min_matches"],
        dot_size = config["dotplot"]["dot_size"],
        dot_alpha = config["dotplot"]["dot_alpha"],
        shared_ogs = config.get("shared_ogs", False),
        orthogroups_tsv = lambda wildcards: os.path.join(
            os.path.dirname(open(f"{RESULTS_DIR}/orthofinder/orthologues_path.txt").read().strip()),
            "Orthogroups", "Orthogroups.tsv") if os.path.exists(f"{RESULTS_DIR}/orthofinder/orthologues_path.txt") else "",
        color_nonsignificant = config["dotplot"].get("color_nonsignificant", False),
        cb_colors = config.get("cb_colors", False)
    log:
        "logs/dotplot_orthofinder_{species1}_{species2}.log"
    script:
        "scripts/run_dotplot_orthofinder.py"

